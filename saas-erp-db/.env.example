# ─────────────────────────────────────────
# Master Database (root-level for provisioning)
# ─────────────────────────────────────────
MASTER_DB_HOST=localhost
MASTER_DB_PORT=3306
MASTER_DB_USER=root
MASTER_DB_PASSWORD=your_root_password_here

# ─────────────────────────────────────────
# Tenant DB Host (where tenant databases live)
# Can be the same as master or a separate server
# ─────────────────────────────────────────
DB_HOST_FOR_TENANTS=localhost
DB_PORT_FOR_TENANTS=3306

# ─────────────────────────────────────────
# Migrations
# ─────────────────────────────────────────
# Absolute path — override if you move the migrations folder
# MIGRATIONS_DIR=/opt/erp/saas-erp-db/tenant/migrations

# ─────────────────────────────────────────
# Backup settings
# ─────────────────────────────────────────
BACKUP_ROOT=./backups
BACKUP_RETENTION=7
BACKUP_COMPRESS=true
MYSQLDUMP_PATH=mysqldump
MYSQL_PATH=mysql

# ─────────────────────────────────────────
# Monitor thresholds
# ─────────────────────────────────────────
MONITOR_SLOW_QUERY_SEC=2
MONITOR_SIZE_ALERT_MB=5120
MONITOR_CONN_ALERT_PCT=80
MONITOR_SCALE_OUT_MB=20480
